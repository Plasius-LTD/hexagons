{
  "name": "@plasius/hexagons",
  "version": "1.0.12",
  "main": "./dist-cjs/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "description": "Hexagonal architecture utilities for Plasius projects",
  "private": false,
  "scripts": {
    "build": "tsc --build --listEmittedFiles && rsync -av --include '*/' --include '*.module.css' --exclude '*' src/ dist/ || true && npm run build:cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "clean": "rimraf dist-cjs dist tsconfig.tsbuildinfo",
    "reset:clean": "rm -rf node_modules package-lock.json && npm run clean",
    "audit:ts": "tsc --noEmit --pretty",
    "audit:eslint": "eslint . --max-warnings=0",
    "audit:deps": "npm ls --all --omit=optional --omit=peer > /dev/null 2>&1 || true",
    "audit:npm": "npm audit --audit-level=high --omit=dev",
    "audit:test": "vitest run --coverage",
    "audit:all": "npm-run-all -l audit:ts audit:eslint audit:deps audit:npm audit:test",
    "build:cjs": "tsc -p tsconfig.json --module commonjs --moduleResolution node --outDir dist-cjs --tsBuildInfoFile dist-cjs/tsconfig.tsbuildinfo --listEmittedFiles && rsync -av --include '*/' --include '*.module.css' --exclude '*' src/ dist-cjs/ || true && node scripts/write-cjs-package-json.cjs",
    "lint": "eslint . --max-warnings=0",
    "prepare": "npm run build",
    "pack:check": "node scripts/verify-public-package.cjs",
    "prepublishOnly": "npm run build && npm run pack:check"
  },
  "author": "Plasius LTD <development@plasius.co.uk>",
  "license": "MIT",
  "dependencies": {
    "@plasius/error": "^1.0.10",
    "@plasius/gpu-world-generator": "^0.0.13",
    "@plasius/gpu-xr": "^0.1.8",
    "@plasius/react-state": "^1.2.7"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "ajv": "^8.18.0",
    "eslint": "^10.1.0",
    "globals": "^17.3.0",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.6.2",
    "tsx": "^4.20.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "zod": "^4.0.17"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/index.js",
  "files": [
    "dist",
    "dist-cjs",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTORS.md",
    "docs",
    "legal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Plasius-LTD/hexagons.git"
  },
  "bugs": {
    "url": "https://github.com/Plasius-LTD/hexagons/issues"
  },
  "homepage": "https://github.com/Plasius-LTD/hexagons#readme",
  "publishConfig": {
    "access": "public"
  },
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/c/plasiusltd/membership"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/Plasius-LTD"
    }
  ],
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
